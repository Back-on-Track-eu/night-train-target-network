# =============================================================================
# Night Train — Dev Environment
# =============================================================================
# Copy this file to .env and fill in your value.
# Never commit .env to version control — it is gitignored.

# Absolute path on YOUR MACHINE to the Google service account JSON key file.
# The file is mounted read-only into the API container at startup.
#
# Examples:
#   macOS:   GOOGLE_APPLICATION_CREDENTIALS=/Users/yourname/keys/service_account.json
#   Linux:   GOOGLE_APPLICATION_CREDENTIALS=/home/yourname/keys/service_account.json
#   Windows: GOOGLE_APPLICATION_CREDENTIALS=C:/Users/yourname/keys/service_account.json

GOOGLE_APPLICATION_CREDENTIALS=
