# =============================================================================
# Night Train Target Network — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/
.Python
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/

# uv
.uv/
uv.lock

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
dist/
.parcel-cache/

# -----------------------------------------------------------------------------
# Docker / Infrastructure
# -----------------------------------------------------------------------------
# Env files with secrets — never commit
backend/docker/.env
backend/db/dev/.env
.devcontainer/.env

# OpenRailRouting — large data and generated graph cache
backend/models/route/routing/docker/data/
backend/models/route/routing/docker/graph-cache/

# Postgres data volume (if mounted locally)
pgdata/

# -----------------------------------------------------------------------------
# Testing/ Test scripts
# -----------------------------------------------------------------------------

# Generated scratch output from backend/scripts/*.py manual test scripts
# (e.g. feedback_categories_output.json) — input fixtures like
# tc_1_evaluation_input.json don't end in "_output.json" so stay tracked.
# backend/scripts/data/*_output.json

# -----------------------------------------------------------------------------
# Claude / AI tooling
# -----------------------------------------------------------------------------
# Claude snapshot tool output — too large for git
project-snapshot.zip
.claude/export-temp/

# -----------------------------------------------------------------------------
# Notes / personal files
# -----------------------------------------------------------------------------
notes/

# Generated at runtime by Docker entrypoint
backend/models/route/routing/countries.geojson

# Scratch files
git_status.txt
test_output.txt

# Credentials
credentials/

# -----------------------------------------------------------------------------
# OS / Editor
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo
*~

# PyCharm
.idea/
*.iml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
deploy/**/.env
