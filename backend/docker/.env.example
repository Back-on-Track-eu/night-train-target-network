# =============================================================================
# Night Train — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# This is the single source of truth for all backend configuration.
# Used by:
#   backend/docker/docker-compose.yml  — main backend stack
#   .devcontainer/docker-compose.yml   — VS Code dev container

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=bot_admin
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=target_network_test_db
POSTGRES_PORT=5432

# ── OpenRailRouting ──────────────────────────────────────────────────────────
# Host port exposed on the Docker host machine (for local tools like Postman)
OPENRAILROUTING_HOST_PORT=8989
# Internal container port (used for inter-container communication)
OPENRAILROUTING_CONTAINER_PORT=8989
# Full URL used by the API container to reach the routing engine
OPENRAILROUTING_URL=http://openrailrouting:8989
OPENRAILROUTING_PROFILE=night_train
OPENRAILROUTING_TIMEOUT=30

# ── Routing data files ───────────────────────────────────────────────────────
# Path to Natural Earth country polygons GeoJSON (baked into Docker image at build time)
COUNTRIES_GEOJSON_PATH=/app/models/route/routing/countries.geojson

# Download URL for country polygons — used by Dockerfile at build time and
# referenced in error messages if the file is missing in local dev
NATURAL_EARTH_COUNTRIES_URL=https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_110m_admin_0_countries.geojson

# Path to OpenRailRouting graph cache (mounted as Docker volume — large, not in git)
GRAPH_CACHE_PATH=/app/models/route/routing/docker/graph-cache

# ── Feedback mail (adapters/mailer.py) ──────────────────────────────────────
# SMTP credentials used to send POST /api/feedback notifications. Feedback is
# still stored in admin.feedback if these are unset or sending fails — see
# mailer.py's module docstring. STARTTLS is used unconditionally (SMTP_PORT
# 587 is the standard STARTTLS submission port).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Envelope From address — defaults to SMTP_USER if left blank
SMTP_FROM=
# Recipient for every feedback submission
FEEDBACK_NOTIFY_EMAIL=targetnetwork-wg@back-on-track.eu

# ── Auth (api/auth.py, api/auth_middleware.py) ───────────────────────────────
# REQUIRED — the API refuses to start without it. Signs the local-plane
# JWTs (OTP contributors + guests). Generate: openssl rand -base64 48
JWT_SECRET=
# true = log OTP codes instead of emailing them (local dev / CI only —
# NEVER on a public deployment). OTP mail otherwise uses the SMTP_* block
# above, same lane as feedback mail.
AUTH_EMAIL_DEV_MODE=false
# true = disable per-IP rate limits on the auth endpoints (local dev / CI)
TESTING=false

# ── "Sign in with BoT account" — Keycloak OIDC operator plane ────────────────
# DORMANT until both are set; activates when BoT's central identity
# (Keycloak realm) goes live. No code change needed at flip time.
# KEYCLOAK_ISSUER_URL=https://auth.back-on-track.eu/realms/bot
# KEYCLOAK_CLIENT_ID=target-network
# Optional override; derived from the issuer by default:
# KEYCLOAK_JWKS_URL=
