# =============================================================================
# Night Train — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Absolute path to your Google service account JSON key file.
# The file will be mounted read-only into the API container.
#
# Examples:
#   Windows:  GOOGLE_APPLICATION_CREDENTIALS=C:/Users/yourname/keys/service_account.json
#   macOS:    GOOGLE_APPLICATION_CREDENTIALS=/Users/yourname/keys/service_account.json
#   Linux:    GOOGLE_APPLICATION_CREDENTIALS=/home/yourname/keys/service_account.json

GOOGLE_APPLICATION_CREDENTIALS=
