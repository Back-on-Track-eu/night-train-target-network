# =============================================================================
# Night Train — Environment Variables
# =============================================================================

# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# This is the single source of truth for all backend configuration.
# Used by:
#   backend/docker/docker-compose.yml  — main backend stack
#   .devcontainer/docker-compose.yml   — VS Code dev container

# ── Testing mode ───────────────────────────────────────────────────────────────

# TESTING=true


# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=bot_admin
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=target_network_test_db
POSTGRES_PORT=5432

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret key for signing JWTs. Must be at least 32 random bytes.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️  REQUIRED — the API will refuse to start if this is missing.
# ⚠️  NEVER reuse across environments. Rotating this invalidates all active sessions.
JWT_SECRET=replace-with-output-of-secrets.token_hex-32

# Resend API key for sending OTP emails.
# Obtain from: https://resend.com/api-keys
# ⚠️  REQUIRED for login to work. In local dev you can use the Resend test key
#     (emails are captured in the Resend dashboard, not delivered).
RESEND_API_KEY=re_replace_with_your_resend_api_key

# From-address for OTP emails. Must be a verified domain in your Resend account.
# For local dev, Resend's sandbox address works without domain verification.
RESEND_FROM_ADDRESS=Night Train Tool <noreply@mail.backontrack.eu>

# RATE_LIMIT_BURST — burst rate limit for POST /api/auth/request-code
# Default: "2 per minute" (production). Uncomment below for local dev if
# you need to call the endpoint rapidly. Tests set this via conftest.py.
# RATE_LIMIT_BURST=1000 per minute

# ── OpenRailRouting ──────────────────────────────────────────────────────────
# Host port exposed on the Docker host machine (for local tools like Postman)
OPENRAILROUTING_HOST_PORT=8989
# Internal container port (used for inter-container communication)
OPENRAILROUTING_CONTAINER_PORT=8989
# Full URL used by the API container to reach the routing engine
OPENRAILROUTING_URL=http://openrailrouting:8989
OPENRAILROUTING_PROFILE=night_train
OPENRAILROUTING_TIMEOUT=30

# ── Routing data files ───────────────────────────────────────────────────────
# Path to Natural Earth country polygons GeoJSON (baked into Docker image at build time)
COUNTRIES_GEOJSON_PATH=/app/models/route/routing/countries.geojson

# Download URL for country polygons — used by Dockerfile at build time and
# referenced in error messages if the file is missing in local dev
NATURAL_EARTH_COUNTRIES_URL=https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_110m_admin_0_countries.geojson

# Path to OpenRailRouting graph cache (mounted as Docker volume — large, not in git)
GRAPH_CACHE_PATH=/app/models/route/routing/docker/graph-cache


