        "hsr_allowed": "Whether this composition may use high-speed rail infrastructure.",
        "min_boarding_time_min": "Vehicle-dependent minimum dwell time at boarding stops. Unit: min",
        "min_alighting_time_min": "Vehicle-dependent minimum dwell time at alighting stops. Unit: min"
      },
      "staff": {
        "driver_factor": "Number of drivers required per trip (e.g. 1 or 2).",
        "crew_factor_total": "Total fractional cabin crew required — sum of crew_factor across all coaches in this composition."
      },
      "energy": {
        "factor_weight": "Energy regression coefficient for tonne-kilometre term. Unit: kWh/(t·km)",
        "factor_speed": "Energy regression coefficient for speed-squared term. Unit: kWh/((km/h)²·km)",
        "factor_terrain": "Energy regression coefficient for terrain profile."
      },
      "capacity": {
        "places": "Total places of this class across all coaches in the composition — summed across coaches.",
        "density": "Places-weighted average density of this class across all coaches in the composition — space units consumed per place, used for cost allocation."
      },
      "equipment": {
        "has_bikes": "True if ANY coach in the composition has bicycle spaces.",
        "has_climatization": "True if ANY coach in the composition has air conditioning.",
        "has_plugs": "True if ANY coach in the composition has passenger power sockets."
      },
      "coaches": {
        "count": "Number of coaches in this composition.",
        "coach_type_id": "Unique coach type identifier (e.g. WLABmz, Bcmz, type1).",
        "position": "Position of the coach in the composition (1 = first coach behind the locomotive).",
        "remarks": null
      },
      "fixed_costs": {
        "purchase_coach_eur": "Total purchase cost for all coaches. Unit: €",
        "coach_avail_per": "Share of calendar days coach fleet is available. Unit: %",
        "coach_amort_years": "Coach amortisation period. Unit: years",
        "cleaning_services_eur_day": "Daily cleaning and service preparation cost. Unit: €/day"
      },
      "variable_km": {
        "coach_maint_eur_km": "Variable coach maintenance cost per km. Unit: €/km"
      }
    },
    "operators": {
      "driver_costs_eur_h": "Driver staff cost per billable hour. Billable hours = driving time + operator_driver_overhead_h. Unit: €/h",
      "crew_costs_eur_h": "Cabin crew cost per billable hour. Unit: €/h",
      "driver_overhead_h": "Fixed overhead hours added per trip for driver cost calculation. Unit: h/trip",
      "crew_overhead_h": "Fixed overhead hours added per trip for crew cost calculation. Unit: h/trip",
      "ebit_margin_per": "Required EBIT margin as a share of revenue. Unit: %",
      "financing_quota_per": "Annual financing cost as a share of total capital employed. Unit: %/year",
      "var_overhead_per": "Variable overhead as a share of total ticket revenue. Unit: %",
      "fix_overhead_quota_per": "Fixed overhead as a share of all other railway operation costs. Unit: %",
      "loco_full_service_lease_eur_h": "Full-service locomotive lease rate, utilization-based — bundles capital, maintenance, and insurance. Billed per loco operating hour (driving + buffer + dwell). Unit: €/h",
      "cost_per_class": "Service and stockings cost per available place per trip. Unit: €/place"
    },
    "indicative": {
      "kpis": {
        "cost_eur_per_train_km": "Total composition cost ÷ reference distance, for the reference trip profile. PLACEHOLDER figure — see models/compositions/calc_indicative_figures.py.",
