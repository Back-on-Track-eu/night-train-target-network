# Target Network app stack — per-environment configuration.
# Copy to .env in the environment's checkout and fill in. chmod 600 .env
# Secrets live in Vaultwarden (Target Network org) — never in git.

# staging | production — drives compose project name, container names,
# volume name (tn_<env>_pgdata).
ENV_NAME=staging

# Localhost debug binds (convention: staging 5056/55433, production 5057/55434;
# 5055 was the retired 23-jun stack).
API_DEBUG_PORT=5056
DB_DEBUG_PORT=55433

POSTGRES_USER=bot_admin
POSTGRES_PASSWORD=
POSTGRES_DB=target_network

# Boot requirement — generate per environment, never share between the two:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# OTP/feedback mail via the association's SMTP (all-inkl). Leave SMTP_* empty
# + AUTH_EMAIL_DEV_MODE=true to log OTP codes instead of sending.
SMTP_HOST=w020e032.kasserver.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
AUTH_EMAIL_DEV_MODE=true

# OIDC plane — leave empty until the Keycloak bot realm + client exist.
# Then: KEYCLOAK_ISSUER_URL=https://auth.back-on-track.eu/realms/bot
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=target-network
