# Copy to .env on the server (chmod 600) — never commit this file.
# Generate strong values: openssl rand -base64 24

# PostgreSQL
POSTGRES_USER=nighttrain
POSTGRES_PASSWORD=
POSTGRES_DB=night_train_db

# pgAdmin — web UI for DB access. Store credentials in vault.back-on-track.eu → TN collection.
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
