    "format:check": "prettier --check .",
    "ci": "npm run lint && npm run format:check"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@mdi/js": "^7.4.47",
    "@primeuix/themes": "^2.0.3",
    "maplibre-gl": "^5.24.0",
    "pinia": "^2.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.3",
    "vue": "^3.5.13",
    "vue-i18n": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tailwindcss/vite": "^4.1.7",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "eslint": "^9.27.0",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^8.0.0",
    "vue-tsc": "^2.2.10"
  }
